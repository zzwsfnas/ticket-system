    "assets": [
      "node_modules/better-sqlite3/build/Release/*.node",
      "public/**/*"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "connect-sqlite3": "^0.9.15",
    "cookie-parser": "^1.4.6",
    "express": "^4.21.0",
    "express-session": "^1.18.0",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.21.0"
  }
}
