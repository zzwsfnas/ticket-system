{
  "name": "ticket-system",
  "version": "1.0.0",
  "description": "变电运维五班操作票典型票系统",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "migrate": "node migrate.js",
    "build:exe": "node build-exe.js"
  },
  "bin": "server.js",
  "pkg": {
    "targets": [
      "node22-win-x64"
